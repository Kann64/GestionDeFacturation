{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "clients": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["createdAt"]
    },
    "factures": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["date_creation", "created_by"]
    }
  }
}
